---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Styled by Layo - Premium Luxury Fashion Portfolio" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/public/SBL-Transperant-logo.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <!-- Google Fonts: Cormorant Garamond for Serifs/Headlines, Manrope for Sans/Body -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=Manrope:wght@200;300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      :root {
        --color-dark: #070605;
        --color-cream: #f7f0e6;
        --color-gold: #c9a96e;
        --color-gold-dark: #a88850;
      }

      body {
        background-color: var(--color-dark);
        color: var(--color-cream);
        font-family: 'Manrope', sans-serif;
        overflow-x: hidden;
      }

      h1, h2, h3, h4, .font-display {
        font-family: 'Cormorant Garamond', serif;
      }

      /* Base custom scrollbar */
      ::-webkit-scrollbar {
        width: 6px;
      }
      ::-webkit-scrollbar-track {
        background: #0d0c0a;
      }
      ::-webkit-scrollbar-thumb {
        background: #c9a96e33;
        border-radius: 3px;
      }
      ::-webkit-scrollbar-thumb:hover {
        background: #c9a96e66;
      }

      /* Custom animations */
      .fade-in-up {
        animation: fadeInUp 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      }

      @keyframes fadeInUp {
        from {
          opacity: 0;
          transform: translateY(20px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
    </style>
  </head>
  <body class="selection:bg-luxury-gold selection:text-black">
    <!-- Luxury Overlay Noise / Texture (Subtle glow) -->
    <div class="fixed inset-0 pointer-events-none z-50 bg-[radial-gradient(circle_at_50%_-20%,rgba(201,169,110,0.04),transparent_60%)]"></div>
    <slot />
  </body>
</html>
