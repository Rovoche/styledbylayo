---
// LookbookGrid.astro
const items = [
  {
    id: "butterfly-gown",
    title: "The Butterfly Gown",
    category: "eveningwear",
    image: "butterfly-beaded-evening-gown.1.jpg",
    details: "Over 480 hours of hand-beading. Three-dimensional organza butterfly extensions engineered for maximum kinetic elegance in motion.",
    linkText: "Inspect Masterwork",
    span: "lg:col-span-2 aspect-[16/10]"
  },
  {
    id: "emerald-gown",
    title: "Emerald Beaded Couture Gown",
    category: "bridal",
    image: "emerald-beaded-couture-gown.1.jpg",
    details: "Deep emerald hand-stitched glass drop crystals cascading gracefully along premium silk tulle lining.",
    linkText: "Inspect Masterwork",
    span: "lg:col-span-1 aspect-[4/5]"
  },
  {
    id: "gold-sculpted",
    title: "The Gold Sculpted Gown",
    category: "eveningwear",
    image: "gold-sculpted-evening-gown.1.jpg",
    details: "High-fashion anatomical structuring and drapes bath in true gold thermal laminates.",
    linkText: "Inspect Masterwork",
    span: "lg:col-span-1 aspect-[4/5]"
  },
  {
    id: "atelier-gown",
    title: "The Atelier Signature Gown",
    category: "bridal",
    image: "SaveClip.App_687606913_18578571397054548_8013286953504668932_n.jpg",
    details: "A breathtaking study of ivory lace and gold thread embroidery, structured with extreme volume flaring and dramatic train dynamics.",
    linkText: "Inspect Masterwork",
    span: "lg:col-span-2 aspect-[16/10]"
  },
  {
    id: "menswear-suit",
    title: "Bespoke Menswear Suit",
    category: "menswear",
    image: "black-embroidered-menswear-suit.1.jpg",
    details: "Premium black wool coat highlighted by hand-dyed gold-metallic brocade embroidery threadings.",
    linkText: "Inspect Masterwork",
    span: "lg:col-span-1 aspect-[4/5]"
  },
  {
    id: "mini-dress",
    title: "Pink & Green Beaded Dress",
    category: "ready-to-wear",
    image: "pink-green-beaded-mini-dress.2.jpg",
    details: "Vibrant custom teal studio campaign dress heavily weighted with hand-threaded bugle beads.",
    linkText: "Inspect Masterwork",
    span: "lg:col-span-1 aspect-[4/5]"
  }
];

const categories = [
  { value: "all", label: "The Complete Archive" },
  { value: "bridal", label: "Bridal Artistry" },
  { value: "eveningwear", label: "Evening Wear" },
  { value: "ready-to-wear", label: "Ready-to-Wear" },
  { value: "menswear", label: "Bespoke Menswear" }
];
---

<section id="archive" class="py-24 lg:py-36 bg-luxury-dark text-luxury-cream px-6 lg:px-16 border-b border-luxury-gold/15 relative">
  <div class="max-w-7xl mx-auto">
    
    <!-- Editorial Header Model -->
    <div class="text-center max-w-2xl mx-auto mb-16 lg:mb-24 flex flex-col items-center">
      <span class="text-[10px] uppercase tracking-[0.6em] text-luxury-gold font-sans font-semibold mb-3">La Collection</span>
      <h2 class="text-4xl lg:text-7xl font-light tracking-wide font-editorial mb-6 text-luxury-cream">
        Couture <span class="italic font-light text-luxury-gold">Archive</span>
      </h2>
      <div class="h-[1px] w-12 bg-luxury-gold/40 mb-6"></div>
      <p class="text-xs font-sans font-light tracking-widest text-luxury-cream/60 uppercase">
        LAGOS, NIGERIA · GLOBAL PREMIERS
      </p>
    </div>

    <!-- Category Filters without boxed containers -->
    <div class="flex flex-wrap justify-center gap-x-8 gap-y-4 mb-20 text-[10px] lg:text-xs uppercase tracking-[0.25em]">
      {categories.map((cat) => (
        <button 
          class:list={[
            "filter-btn py-2 border-b-2 border-transparent transition-all duration-500 hover:text-luxury-gold font-sans font-medium pointer-events-auto",
            cat.value === "all" ? "active-filter text-luxury-gold border-luxury-gold/60" : "text-luxury-cream/50"
          ]}
          data-category={cat.value}
        >
          {cat.label}
        </button>
      ))}
    </div>

    <!-- Lookbook Editorial Grid: No boxed borders or solid cards, asymmetric layout -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-16 items-start" id="lookbook-grid">
      {items.map((item) => (
        <div 
          class={`lookbook-item group relative flex flex-col justify-start overflow-hidden cursor-zoom-in duration-500 transform ${item.span}`}
          data-category={item.category}
          data-image={`${import.meta.env.BASE_URL}${item.image}`}
          data-title={item.title}
          data-details={item.details}
        >
          <!-- Frame with thin golden accent overlay on hover -->
          <div class="relative w-full h-[82%] overflow-hidden bg-black/40 border border-luxury-gold/5 transition-colors duration-700 group-hover:border-luxury-gold/25 flex items-center justify-center">
            <img 
              src={`${import.meta.env.BASE_URL}${item.image}`} 
              alt={item.title}
              referrerpolicy="no-referrer"
              class="h-full w-full object-contain md:object-cover transform scale-100 group-hover:scale-103 transition-transform duration-[4000ms] ease-out select-none"
            />
            <div class="absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
            <!-- Interactive trigger cue on hover -->
            <div class="absolute top-4 right-4 text-luxury-gold opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none text-xs">
              ✦
            </div>
          </div>

          <!-- Magazine Style Credit Captions (Replaces uniform footer) -->
          <div class="pt-4 flex flex-col items-start select-none">
            <div class="flex items-center space-x-2 text-[8px] uppercase tracking-[0.3em] text-luxury-gold mb-1 font-semibold">
              <span>{item.category.replace("-", " ")}</span>
              <span>·</span>
              <span>Edition SBL</span>
            </div>
            <h3 class="font-editorial text-xl lg:text-2xl font-light tracking-wide text-luxury-cream group-hover:text-luxury-gold transition-colors duration-300">
              {item.title}
            </h3>
            <p class="text-[10px] uppercase tracking-widest text-luxury-cream/40 mt-1 font-sans group-hover:text-luxury-cream/70 transition-colors">
              Inspect haute couture lines →
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- LIGHTBOX / FULL GARMENT INSPECTOR -->
  <div id="lightbox" class="fixed inset-0 z-50 bg-[#070605]/98 backdrop-blur-xl opacity-0 pointer-events-none transition-all duration-500 flex flex-col justify-between py-8 px-6">
    <!-- Close Header -->
    <div class="flex justify-between items-center w-full max-w-7xl mx-auto z-10">
      <div class="flex items-center space-x-3">
        <img 
          src={`${import.meta.env.BASE_URL}SBL-Transperant-logo.png`} 
          alt="SBL Logo" 
          class="h-8 w-8 object-contain brightness-0 invert" 
          referrerpolicy="no-referrer"
        />
        <span class="font-display text-xs lg:text-sm font-light tracking-[0.25em] text-luxury-gold uppercase">SBL Couture Inspector</span>
      </div>
      <button id="close-lightbox" class="text-luxury-cream hover:text-luxury-gold transition-colors text-xs uppercase tracking-[0.3em] font-sans p-3 flex items-center space-x-2">
        <span>Close</span>
        <span class="text-lg">×</span>
      </button>
    </div>

    <!-- Active Image & Data -->
    <div class="flex-1 flex flex-col lg:flex-row items-center justify-center max-w-7xl mx-auto w-full gap-8 lg:gap-16 my-4 select-none">
      <!-- Media Frame (Force object-contain so we NEVER Crop Model Face or Garment Details!) -->
      <div class="h-[50vh] lg:h-[75vh] w-full lg:w-3/5 flex justify-center items-center relative overflow-hidden bg-black/50 border border-luxury-gold/10 shadow-2xl">
        <img 
          id="lightbox-img" 
          src="" 
          alt="Active Masterpiece detail" 
          referrerpolicy="no-referrer"
          class="h-full max-h-full max-w-full object-contain select-none"
        />
      </div>

      <!-- Description Frame -->
      <div class="w-full lg:w-2/5 flex flex-col justify-center text-left">
        <span id="lightbox-cat" class="text-[9px] uppercase tracking-[0.5em] text-luxury-gold font-sans font-semibold mb-3">La Couture</span>
        <h3 id="lightbox-title" class="text-3xl lg:text-5xl font-light tracking-wide font-editorial mb-6 text-luxury-cream leading-tight">Masterwork Name</h3>
        <p id="lightbox-desc" class="text-sm font-sans font-light text-luxury-cream/80 leading-relaxed max-w-md pb-8 border-b border-luxury-gold/20">
          This exclusive piece forms part of our high luxury line. Constructed completely by hand in our Lagos atelier based on custom millimeter fittings.
        </p>
        
        <!-- Luxury features -->
        <div class="mt-8 grid grid-cols-2 gap-4 text-[10px] uppercase tracking-[0.18em] font-sans text-luxury-cream/60">
          <div>
            <span class="block text-luxury-gold font-medium mb-1">Authenticity</span>
            <span>Serialized Maison SBL</span>
          </div>
          <div>
            <span class="block text-luxury-gold font-medium mb-1">Tailoring</span>
            <span>Bespoke Couture Stitching</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Footer Credit Separations -->
    <div class="w-full text-center text-[9px] text-luxury-cream/30 uppercase tracking-[0.4em] z-10 pb-2">
      CONCEPT INTENSITY BY ROVOCHÉ · PRESS &lt;ESC&gt; TO CLOSE
    </div>
  </div>
</section>

<script>
  // Filter and Lightbox Interactions
  const filterButtons = document.querySelectorAll('.filter-btn');
  const items = document.querySelectorAll('.lookbook-item');
  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const lightboxCat = document.getElementById('lightbox-cat');
  const lightboxTitle = document.getElementById('lightbox-title');
  const lightboxDesc = document.getElementById('lightbox-desc');
  const closeBtn = document.getElementById('close-lightbox');

  // Filter Code
  filterButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      // Manage active style
      filterButtons.forEach(b => {
        b.classList.remove('active-filter', 'text-luxury-gold', 'border-luxury-gold/60');
        b.classList.add('text-luxury-cream/50');
      });

      btn.classList.add('active-filter', 'text-luxury-gold', 'border-luxury-gold/60');
      btn.classList.remove('text-luxury-cream/50');

      const filterVal = btn.getAttribute('data-category');

      // Animating Cards
      items.forEach(item => {
        const itemCategory = item.getAttribute('data-category');
        if (filterVal === 'all' || itemCategory === filterVal) {
          item.classList.remove('hidden');
          // Smooth fade in
          setTimeout(() => {
            (item as HTMLElement).style.opacity = '1';
            (item as HTMLElement).style.transform = 'scale(1)';
          }, 30);
        } else {
          (item as HTMLElement).style.opacity = '0';
          (item as HTMLElement).style.transform = 'scale(0.97)';
          setTimeout(() => {
            item.classList.add('hidden');
          }, 400);
        }
      });
    });
  });

  // Lightbox Open Code
  items.forEach(item => {
    item.addEventListener('click', () => {
      const imgPath = item.getAttribute('data-image') || '';
      const titleText = item.getAttribute('data-title') || '';
      const categoryText = (item.getAttribute('data-category') || 'Couture').replace("-", " ");
      const descText = item.getAttribute('data-details') || '';

      if (lightboxImg) lightboxImg.src = imgPath;
      if (lightboxTitle) lightboxTitle.textContent = titleText;
      if (lightboxCat) lightboxCat.textContent = categoryText;
      if (lightboxDesc) lightboxDesc.textContent = descText;

      // Reveal Lightbox
      lightbox?.classList.remove('pointer-events-none', 'opacity-0');
      lightbox?.classList.add('opacity-100');
    });
  });

  // Lightbox Close Code
  function closeLightbox() {
    lightbox?.classList.add('pointer-events-none', 'opacity-0');
    lightbox?.classList.remove('opacity-100');
  }

  closeBtn?.addEventListener('click', closeLightbox);
  lightbox?.addEventListener('click', (e) => {
    if (e.target === lightbox) {
      closeLightbox();
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      closeLightbox();
    }
  });
</script>
