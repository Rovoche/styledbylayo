---
// LookbookGrid.astro
const base = import.meta.env.BASE_URL;
const items = [
  {
    id: "butterfly-gown",
    title: "The Butterfly Gown",
    category: "eveningwear",
    image: `${base}butterfly-beaded-evening-gown.1.jpg`,
    details: "Over 480 hours of hand-beading. 3D organza butterfly appliques styled for optimal volume.",
    linkText: "View Masterwork"
  },
  {
    id: "emerald-gown",
    title: "Emerald Beaded Couture Gown",
    category: "bridal",
    image: `${base}emerald-beaded-couture-gown.1.jpg`,
    details: "Vibrant emerald hand-stitched glass beads cascading along premium silk tulle.",
    linkText: "View Masterwork"
  },
  {
    id: "gold-sculpted",
    title: "Gold Sculpted Gown",
    category: "eveningwear",
    image: `${base}gold-sculpted-evening-gown.1.jpg`,
    details: "High-fashion metallurgical shaping and drapes outlining structural luxury lines.",
    linkText: "View Masterwork"
  },
  {
    id: "menswear-suit",
    title: "Black Embroidered Jacket",
    category: "menswear",
    image: `${base}black-embroidered-menswear-suit.1.jpg`,
    details: "Hand-threaded custom gold brocade embroidery structured from premium Nigerian wool.",
    linkText: "View Masterwork"
  },
  {
    id: "mini-dress",
    title: "Pink & Green Beaded Dress",
    category: "ready-to-wear",
    image: `${base}pink-green-beaded-mini-dress.2.jpg`,
    details: "Bright pink and green hand-threaded bugle beads over sleek luxury mesh.",
    linkText: "View Masterwork"
  }
];

const categories = [
  { value: "all", label: "The Complete Archive" },
  { value: "bridal", label: "Bridal Artistry" },
  { value: "eveningwear", label: "Evening Wear" },
  { value: "ready-to-wear", label: "Ready-to-Wear" },
  { value: "menswear", label: "Bespoke Menswear" }
];
---

<section id="archive" class="py-24 lg:py-36 bg-[#0b0a09] borders-b border-luxury-gold/10 px-6 lg:px-12 relative">
  <div class="max-w-7xl mx-auto">
    <!-- Header Block -->
    <div class="text-center max-w-2xl mx-auto mb-16 lg:mb-24 flex flex-col items-center">
      <span class="text-[10px] uppercase tracking-[0.6em] text-luxury-gold font-sans font-semibold mb-3">La Collection</span>
      <h2 class="text-4xl lg:text-6xl font-light tracking-wide font-editorial mb-6 text-luxury-cream">
        Couture <span class="italic font-light text-luxury-gold">Archive</span>
      </h2>
      <div class="h-[1px] w-12 bg-luxury-gold/40 mb-6"></div>
      <p class="text-xs font-sans font-light tracking-wider text-luxury-cream/60 uppercase">
        Lagos, Nigeria • Established Haute Couture Portfolio
      </p>
    </div>

    <!-- Category Filters -->
    <div class="flex flex-wrap justify-center gap-x-6 gap-y-4 mb-16 lg:mb-24 text-[10px] lg:text-xs uppercase tracking-[0.25em]">
      {categories.map((cat) => (
        <button 
          class:list={[
            "filter-btn px-4 py-2 border border-transparent transition-all duration-500 hover:text-luxury-gold font-sans font-medium pointer-events-auto",
            cat.value === "all" ? "active-filter text-luxury-gold border-luxury-gold/20 bg-luxury-gold/5" : "text-luxury-cream/70"
          ]}
          data-category={cat.value}
        >
          {cat.label}
        </button>
      ))}
    </div>

    <!-- Editorial Bento Grid / Layout -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-12" id="lookbook-grid">
      {items.map((item) => (
        <div 
          class="lookbook-card group relative bg-[#070605] border border-luxury-gold/10 overflow-hidden flex flex-col justify-between p-6 aspect-[4/5] hover:border-luxury-gold/30 transition-all duration-700 block cursor-zoom-in"
          data-category={item.category}
          data-image={item.image}
          data-title={item.title}
          data-details={item.details}
        >
          <!-- Subtle Glow Overlay -->
          <div class="absolute inset-x-0 top-0 h-1/2 bg-gradient-to-t from-transparent to-black/30 opacity-60 pointer-events-none"></div>

          <!-- Top Section: Title & Category -->
          <div class="z-10 flex justify-between items-start">
            <div>
              <span class="text-[8px] uppercase tracking-[0.35em] text-luxury-gold font-sans block mb-1">
                {item.category.replace("-", " ")}
              </span>
              <h3 class="font-editorial text-2xl lg:text-3xl font-thin tracking-wide text-luxury-cream group-hover:text-luxury-gold transition-colors duration-500">
                {item.title}
              </h3>
            </div>
            <div class="text-luxury-gold/30 group-hover:text-luxury-gold/80 transition-colors duration-500">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                <path fill-rule="evenodd" d="M14 2.5a.5.5 0 0 0-.5-.5h-6a.5.5 0 0 0 0 1h4.793L2.146 13.146a.5.5 0 0 0 .708.708L13 3.707V8.5a.5.5 0 0 0 1 0v-6z"/>
              </svg>
            </div>
          </div>

          <!-- Centered Image Container -->
          <div class="absolute inset-0 opacity-15 group-hover:opacity-100 transition-opacity duration-1000 overflow-hidden flex items-center justify-center pointer-events-none">
            <img 
              src={item.image} 
              alt={item.title}
              referrerpolicy="no-referrer"
              class="w-full h-full object-contain md:object-cover transform group-hover:scale-105 transition-transform duration-[12002ms] ease-out"
            />
          </div>

          <!-- Bottom Section: Summary -->
          <div class="z-10 mt-auto pt-6 border-t border-luxury-gold/5 opacity-80 group-hover:opacity-100 transition-all duration-500">
            <p class="text-xs font-sans font-light text-luxury-cream/60 leading-relaxed group-hover:text-luxury-cream/90 transition-colors duration-500 line-clamp-2">
              {item.details}
            </p>
            <span class="text-[9px] uppercase tracking-[0.35em] text-luxury-gold font-sans block mt-4 font-semibold group-hover:translate-x-1 transition-transform duration-500">
              {item.linkText} →
            </span>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- LIGHTBOX / FULL GARMENT INSPECTOR -->
  <div id="lightbox" class="fixed inset-0 z-50 bg-[#070605]/95 backdrop-blur-md opacity-0 pointer-events-none transition-all duration-500 flex flex-col justify-between py-8 px-6">
    <!-- Close Header -->
    <div class="flex justify-between items-center w-full max-w-7xl mx-auto z-10">
      <span class="font-display text-xs lg:text-sm font-light tracking-[0.2em] text-luxury-gold">SBL Haute Couture Inspector</span>
      <button id="close-lightbox" class="text-luxury-cream hover:text-luxury-gold transition-colors text-xs uppercase tracking-[0.3em] font-sans p-3 flex items-center space-x-2">
        <span>Close</span>
        <span class="text-lg">×</span>
      </button>
    </div>

    <!-- Active Image & Data -->
    <div class="flex-1 flex flex-col lg:flex-row items-center justify-center max-w-7xl mx-auto w-full gap-8 lg:gap-16 my-4 select-none">
      <!-- Media Frame (Force object-contain so we NEVER Crop Model Face or Garment Details!) -->
      <div class="h-[50vh] lg:h-[75vh] w-full lg:w-3/5 flex justify-center items-center relative overflow-hidden bg-black/40 border border-luxury-gold/10">
        <img 
          id="lightbox-img" 
          src="" 
          alt="Active Masterpiece detail" 
          referrerpolicy="no-referrer"
          class="h-full max-h-full max-w-full object-contain select-none"
        />
      </div>

      <!-- Description Frame -->
      <div class="w-full lg:w-2/5 flex flex-col justify-center">
        <span id="lightbox-cat" class="text-[9px] uppercase tracking-[0.5em] text-luxury-gold font-sans font-semibold mb-3">La Couture</span>
        <h3 id="lightbox-title" class="text-3xl lg:text-5xl font-light tracking-wide font-editorial mb-6 text-luxury-cream leading-tight">Masterwork Name</h3>
        <p id="lightbox-desc" class="text-sm font-sans font-light text-luxury-cream/80 leading-relaxed max-w-md pb-8 border-b border-luxury-gold/20">
          This exclusive piece forms part of our high luxury line. Configured for select exhibition runways, and handmade to order based on custom millimeter fittings.
        </p>
        
        <!-- Luxury features -->
        <div class="mt-8 grid grid-cols-2 gap-4 text-[10px] uppercase tracking-[0.18em] font-sans text-luxury-cream/60">
          <div>
            <span class="block text-luxury-gold font-medium mb-1">Authenticity</span>
            <span>Uniquely Serialized SBL</span>
          </div>
          <div>
            <span class="block text-luxury-gold font-medium mb-1">Tailoring</span>
            <span>Bespoke Hand Stitching</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Footer Inspired Info -->
    <div class="w-full text-center text-[9px] text-luxury-cream/30 uppercase tracking-[0.4em] z-10 pb-2">
      Demo concept inspired by ROVOCHÉ aesthetic direction
    </div>
  </div>
</section>

<script>
  // Filter and Lightbox Interactions
  const filterButtons = document.querySelectorAll('.filter-btn');
  const cards = document.querySelectorAll('.lookbook-card');
  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const lightboxCat = document.getElementById('lightbox-cat');
  const lightboxTitle = document.getElementById('lightbox-title');
  const lightboxDesc = document.getElementById('lightbox-desc');
  const closeBtn = document.getElementById('close-lightbox');

  // Filter Code
  filterButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      // Manage active style
      filterButtons.forEach(b => {
        b.classList.remove('active-filter', 'text-luxury-gold', 'border-luxury-gold/20', 'bg-luxury-gold/5');
        b.classList.add('text-luxury-cream/70');
      });

      btn.classList.add('active-filter', 'text-luxury-gold', 'border-luxury-gold/20', 'bg-luxury-gold/5');
      btn.classList.remove('text-luxury-cream/70');

      const filterVal = btn.getAttribute('data-category');

      // Animating Cards
      cards.forEach(card => {
        const itemCategory = card.getAttribute('data-category');
        if (filterVal === 'all' || itemCategory === filterVal) {
          card.classList.remove('hidden');
          // Smooth anim re-add
          setTimeout(() => {
            (card as HTMLElement).style.opacity = '1';
            (card as HTMLElement).style.transform = 'scale(1)';
          }, 50);
        } else {
          (card as HTMLElement).style.opacity = '0';
          (card as HTMLElement).style.transform = 'scale(0.95)';
          setTimeout(() => {
            card.classList.add('hidden');
          }, 400);
        }
      });
    });
  });

  // Lightbox Open Code
  cards.forEach(card => {
    card.addEventListener('click', () => {
      const imgPath = card.getAttribute('data-image') || '';
      const titleText = card.getAttribute('data-title') || '';
      const categoryText = (card.getAttribute('data-category') || 'Couture').replace("-", " ");
      const descText = card.getAttribute('data-details') || '';

      if (lightboxImg) lightboxImg.src = imgPath;
      if (lightboxTitle) lightboxTitle.textContent = titleText;
      if (lightboxCat) lightboxCat.textContent = categoryText;
      if (lightboxDesc) lightboxDesc.textContent = descText;

      // Reveal Lightbox
      lightbox?.classList.remove('pointer-events-none', 'opacity-0');
      lightbox?.classList.add('opacity-100');
    });
  });

  // Lightbox Close Code
  function closeLightbox() {
    lightbox?.classList.add('pointer-events-none', 'opacity-0');
    lightbox?.classList.remove('opacity-100');
  }

  closeBtn?.addEventListener('click', closeLightbox);
  lightbox?.addEventListener('click', (e) => {
    // Only close if clicking the backdrop, not our interactive contents
    if (e.target === lightbox) {
      closeLightbox();
    }
  });

  // Escape key support for accessibility
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      closeLightbox();
    }
  });
</script>
