---
// Hero.astro
const base = import.meta.env.BASE_URL;

const slides = [
  { image: `${base}emerald-beaded-couture-gown.1.jpg`, caption: "The Emerald Couture Gown" },
  { image: `${base}butterfly-beaded-evening-gown.1.jpg`, caption: "The Butterfly Beaded Gown" },
  { image: `${base}gold-sculpted-evening-gown.1.jpg`, caption: "The Gold Sculpted Gown" },
  { image: `${base}black-embroidered-menswear-suit.1.jpg`, caption: "Black Embroidered Menswear" },
  { image: `${base}pink-green-beaded-mini-dress.2.jpg`, caption: "Pink & Green Beaded Dress" },
];
---

<!-- Branded Header -->
<header class="absolute top-0 left-0 w-full z-40 px-6 py-6 lg:px-12 lg:py-8 flex justify-between items-center">
  <a href="#top" class="flex items-center gap-3 group">
    <img
      src={`${base}SBL-Transperant-logo.png`}
      alt="Styledbylayo crest"
      class="w-8 h-8 lg:w-10 lg:h-10 object-contain brightness-0 invert opacity-90 group-hover:opacity-100 transition-opacity duration-300"
    />
    <div class="flex flex-col leading-none">
      <span class="font-display text-base lg:text-xl font-light tracking-[0.2em] text-luxury-cream group-hover:text-luxury-gold transition-colors duration-300">
        STYLEDBYLAYO
      </span>
      <span class="text-[7px] lg:text-[8px] uppercase tracking-[0.3em] text-luxury-gold/70 font-sans font-medium mt-1">
        Seven Star Fashion Designer
      </span>
    </div>
  </a>

  <button id="menu-trigger" aria-label="Open menu" aria-expanded="false" class="flex items-center gap-3 text-luxury-cream hover:text-luxury-gold transition-colors duration-300 group">
    <span class="text-[10px] uppercase tracking-[0.35em] font-sans font-medium hidden sm:inline">Menu</span>
    <span class="flex flex-col justify-between h-3 w-5">
      <span class="w-full h-[1px] bg-current"></span>
      <span class="w-full h-[1px] bg-current"></span>
    </span>
  </button>
</header>

<!-- Full-Screen Nav Overlay -->
<div id="nav-overlay" class="fixed inset-0 z-50 bg-[#070605] flex flex-col justify-center items-center gap-7 lg:gap-9 uppercase tracking-[0.35em] font-editorial text-2xl lg:text-4xl font-light text-luxury-cream opacity-0 pointer-events-none transition-opacity duration-500">
  <button id="close-nav" aria-label="Close menu" class="absolute top-7 right-6 lg:top-9 lg:right-12 text-luxury-cream hover:text-luxury-gold transition-colors text-2xl font-sans">×</button>
  <a href="#signature" class="nav-link hover:text-luxury-gold transition-colors duration-300">Masterpieces</a>
  <a href="#archive" class="nav-link hover:text-luxury-gold transition-colors duration-300">Archive</a>
  <a href="#academy" class="nav-link hover:text-luxury-gold transition-colors duration-300">SBLFA Academy</a>
  <a href="#craft" class="nav-link hover:text-luxury-gold transition-colors duration-300">Our Ethos</a>
  <a href="#contact" class="nav-link border border-luxury-gold/40 px-8 py-3 text-sm lg:text-base tracking-[0.3em] text-luxury-gold hover:bg-luxury-gold hover:text-black transition-all duration-300 mt-2">Private Consultation</a>
</div>

<section id="top" class="relative min-h-screen w-full bg-luxury-dark overflow-hidden flex flex-col pt-24 pb-6">
  <!-- Slideshow frame — explicit height so the nested h-full images always resolve -->
  <div class="relative z-10 w-full flex items-center justify-center px-4 lg:px-8 h-[40vh] lg:h-[52vh]">
    <div class="relative h-full w-full max-w-3xl flex items-center justify-center">
      {slides.map((slide, i) => (
        <img
          src={slide.image}
          alt={slide.caption}
          referrerpolicy="no-referrer"
          class="hero-slide absolute h-full w-auto object-contain transition-opacity duration-[1500ms] ease-in-out"
          data-slide-index={i}
          style={i === 0 ? "opacity:1" : "opacity:0"}
        />
      ))}
    </div>
  </div>

  <!-- One persistent brand statement, overlaid on the slideshow, never changes -->
  <div class="relative z-20 w-full px-6 lg:px-12 pt-4 pb-4 text-center bg-gradient-to-t from-luxury-dark via-luxury-dark/95 to-transparent">
    <span class="text-[10px] lg:text-xs uppercase tracking-[0.5em] text-luxury-gold font-sans font-semibold mb-3 block">
      Lagos &middot; Seven Star Couture
    </span>
    <h1 class="text-3xl sm:text-4xl lg:text-6xl font-thin font-editorial leading-[1.05] text-luxury-cream max-w-4xl mx-auto">
      This is not ready-to-wear.<br />
      <span class="italic text-luxury-gold font-light">This is couture.</span>
    </h1>
    <p class="text-xs lg:text-sm font-sans font-light tracking-wide text-luxury-cream/60 mt-3 max-w-md mx-auto">
      Seven-star craftsmanship, hand-built in Lagos for one woman at a time.
    </p>

    <a href="#signature" class="group inline-flex items-center gap-3 text-xs uppercase tracking-[0.3em] font-sans font-medium text-luxury-cream hover:text-luxury-gold transition-colors duration-300 mt-5">
      <span class="border-b border-luxury-gold/50 pb-1 group-hover:border-luxury-gold transition-colors">Enter the Atelier</span>
      <span class="transition-transform duration-300 group-hover:translate-x-1">&rarr;</span>
    </a>

    <!-- Slide indicators — auto-advance, but clickable too -->
    <div class="flex items-center justify-center gap-3 mt-4">
      {slides.map((_, i) => (
        <button
          class="slide-dot w-1.5 h-1.5 rounded-full transition-all duration-300"
          data-slide-index={i}
          class:list={[i === 0 ? "bg-luxury-gold w-4" : "bg-luxury-cream/30"]}
          aria-label={`Show slide ${i + 1}`}
        />
      ))}
    </div>
  </div>
</section>

<script>
  const trigger = document.getElementById('menu-trigger');
  const overlay = document.getElementById('nav-overlay');
  const closeBtn = document.getElementById('close-nav');
  const navLinks = overlay?.querySelectorAll('.nav-link');

  function openNav() {
    overlay?.classList.remove('pointer-events-none', 'opacity-0');
    overlay?.classList.add('opacity-100');
    trigger?.setAttribute('aria-expanded', 'true');
  }
  function closeNav() {
    overlay?.classList.add('pointer-events-none', 'opacity-0');
    overlay?.classList.remove('opacity-100');
    trigger?.setAttribute('aria-expanded', 'false');
  }
  trigger?.addEventListener('click', openNav);
  closeBtn?.addEventListener('click', closeNav);
  navLinks?.forEach(link => link.addEventListener('click', closeNav));
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeNav(); });

  // Slideshow — auto-advance every 4.5s, crossfade, click dots to jump
  const slideEls = document.querySelectorAll('.hero-slide');
  const dots = document.querySelectorAll('.slide-dot');
  let current = 0;
  let timer: number;

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function showSlide(index: number) {
    slideEls.forEach(el => {
      (el as HTMLElement).style.opacity = el.getAttribute('data-slide-index') === String(index) ? '1' : '0';
    });
    dots.forEach(dot => {
      const isActive = dot.getAttribute('data-slide-index') === String(index);
      dot.classList.toggle('bg-luxury-gold', isActive);
      dot.classList.toggle('w-4', isActive);
      dot.classList.toggle('bg-luxury-cream/30', !isActive);
    });
    current = index;
  }

  function nextSlide() {
    showSlide((current + 1) % slideEls.length);
  }

  function startAutoplay() {
    if (prefersReducedMotion) return;
    stopAutoplay();
    timer = window.setInterval(nextSlide, 4500);
  }
  function stopAutoplay() {
    if (timer) clearInterval(timer);
  }

  dots.forEach(dot => {
    dot.addEventListener('click', () => {
      showSlide(Number(dot.getAttribute('data-slide-index')));
      startAutoplay();
    });
  });

  startAutoplay();
</script>
