---
// Hero.astro
const base = import.meta.env.BASE_URL;

const slides = [
  {
    image: `${base}emerald-beaded-couture-gown.1.jpg`,
    caption: "The Emerald Couture Gown",
    w: 1080, h: 1350,
    glowA: "rgba(20,110,75,0.32)",
    glowB: "rgba(130,95,45,0.16)",
  },
  {
    image: `${base}butterfly-beaded-evening-gown.1.jpg`,
    caption: "The Butterfly Beaded Gown",
    w: 1080, h: 1350,
    glowA: "rgba(140,95,45,0.30)",
    glowB: "rgba(70,45,20,0.20)",
  },
  {
    image: `${base}gold-sculpted-evening-gown.1.jpg`,
    caption: "The Gold Sculpted Gown",
    w: 1080, h: 1349,
    glowA: "rgba(210,140,70,0.32)",
    glowB: "rgba(110,50,18,0.20)",
  },
  {
    image: `${base}black-embroidered-menswear-suit.1.jpg`,
    caption: "Black Embroidered Menswear",
    w: 1080, h: 1349,
    glowA: "rgba(124,25,35,0.26)",
    glowB: "rgba(50,25,20,0.20)",
  },
  {
    image: `${base}pink-green-beaded-mini-dress.2.jpg`,
    caption: "Pink & Green Beaded Dress",
    w: 1080, h: 1350,
    glowA: "rgba(195,70,120,0.26)",
    glowB: "rgba(35,75,90,0.22)",
  },
];
---

<!-- Branded Header -->
<header class="absolute top-0 left-0 w-full z-40 px-6 py-6 lg:px-12 lg:py-8 flex justify-between items-center hero-fade-in" style="animation-delay: 0.1s">
  <a href="#top" class="flex items-center gap-3 group">
    <img
      src={`${base}SBL-Transperant-logo.png`}
      alt="Styledbylayo crest"
      width="40" height="40"
      class="w-8 h-8 lg:w-10 lg:h-10 object-contain brightness-0 invert opacity-90 group-hover:opacity-100 transition-opacity duration-300"
    />
    <div class="flex flex-col leading-none">
      <span class="font-display text-base lg:text-xl font-light tracking-[0.2em] text-luxury-cream group-hover:text-luxury-gold transition-colors duration-300">
        STYLEDBYLAYO
      </span>
      <span class="text-[7px] lg:text-[8px] uppercase tracking-[0.3em] text-luxury-gold/70 font-sans font-medium mt-1">
        Seven Star Fashion Designer
      </span>
    </div>
  </a>

  <button id="menu-trigger" aria-label="Open menu" aria-expanded="false" class="flex items-center gap-3 text-luxury-cream hover:text-luxury-gold transition-colors duration-300 group">
    <span class="text-[10px] uppercase tracking-[0.35em] font-sans font-medium hidden sm:inline">Menu</span>
    <span class="flex flex-col justify-between h-3 w-5">
      <span class="w-full h-[1px] bg-current"></span>
      <span class="w-full h-[1px] bg-current"></span>
    </span>
  </button>
</header>

<!-- Small top scrim, just for header legibility over a full-bleed image -->
<div class="absolute top-0 left-0 w-full h-28 z-30 bg-gradient-to-b from-black/45 to-transparent pointer-events-none"></div>

<!-- Full-Screen Nav Overlay -->
<div id="nav-overlay" class="fixed inset-0 z-50 bg-[#070605] flex flex-col justify-center items-center gap-7 lg:gap-9 uppercase tracking-[0.35em] font-editorial text-2xl lg:text-4xl font-light text-luxury-cream opacity-0 pointer-events-none transition-opacity duration-500">
  <button id="close-nav" aria-label="Close menu" class="absolute top-7 right-6 lg:top-9 lg:right-12 text-luxury-cream hover:text-luxury-gold transition-colors text-2xl font-sans">×</button>
  <a href="#signature" class="nav-link hover:text-luxury-gold transition-colors duration-300">Masterpieces</a>
  <a href="#archive" class="nav-link hover:text-luxury-gold transition-colors duration-300">Archive</a>
  <a href="#academy" class="nav-link hover:text-luxury-gold transition-colors duration-300">SBLFA Academy</a>
  <a href="#craft" class="nav-link hover:text-luxury-gold transition-colors duration-300">Our Ethos</a>
  <a href="#contact" class="nav-link border border-luxury-gold/40 px-8 py-3 text-sm lg:text-base tracking-[0.3em] text-luxury-gold hover:bg-luxury-gold hover:text-black transition-all duration-300 mt-2">Private Consultation</a>
</div>

<section id="top" class="relative min-h-screen w-full bg-[#070605] overflow-hidden">

  <!-- Dynamic atmospheric backgrounds — one per garment, crossfaded -->
  <div class="absolute inset-0 z-0">
    {slides.map((slide, i) => (
      <div
        class="ambient-glow absolute inset-0 transition-opacity duration-[1800ms] ease-in-out"
        data-slide-index={i}
        style={`opacity:${i === 0 ? 1 : 0}; background: radial-gradient(ellipse 60% 50% at 20% 25%, ${slide.glowA}, transparent 65%), radial-gradient(ellipse 55% 45% at 80% 75%, ${slide.glowB}, transparent 65%);`}
      />
    ))}
  </div>

  <div class="relative z-10 max-w-7xl mx-auto w-full lg:min-h-screen grid grid-cols-1 lg:grid-cols-12 lg:items-center">

    <!-- IMAGE — full-bleed on mobile (order-1, on top), right column on desktop (order-2) -->
    <div class="order-1 lg:order-2 lg:col-span-7 relative">
      <div id="image-reveal-wrapper" class="hero-reveal-clip relative w-full aspect-[4/5] lg:aspect-auto lg:h-[78vh] overflow-hidden">
        <div id="parallax-frame" class="relative w-full h-full">
          {slides.map((slide, i) => (
            <img
              src={slide.image}
              alt={slide.caption}
              width={slide.w}
              height={slide.h}
              fetchpriority={i === 0 ? "high" : "low"}
              referrerpolicy="no-referrer"
              class="hero-slide absolute inset-0 w-full h-full object-contain transition-opacity duration-[1500ms] ease-in-out"
              data-slide-index={i}
              style={i === 0 ? "opacity:1" : "opacity:0"}
            />
          ))}
        </div>
      </div>
    </div>

    <!-- TEXT — below the photo on mobile (order-2), left column on desktop (order-1) -->
    <div class="order-2 lg:order-1 lg:col-span-5 px-6 lg:px-12 py-9 lg:py-0 text-left hero-fade-in" style="animation-delay: 0.55s">
      <span class="text-[10px] lg:text-xs uppercase tracking-[0.5em] text-luxury-gold font-sans font-semibold mb-4 flex items-center gap-3">
        <span class="w-6 h-px bg-luxury-gold/60"></span>
        Lagos &middot; Seven-Star Couture
      </span>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl xl:text-6xl font-thin font-editorial leading-[1.08] text-luxury-cream max-w-md">
        This Is Not Ready-To-Wear.<br />
        <span class="italic text-luxury-gold font-light">This Is Couture.</span>
      </h1>
      <p class="text-xs lg:text-sm font-sans font-light tracking-wide text-luxury-cream/60 mt-4 max-w-sm">
        Seven-star craftsmanship, hand-built in Lagos for women who demand distinction.
      </p>

      <a href="#signature" class="group inline-flex items-center gap-3 text-xs uppercase tracking-[0.3em] font-sans font-medium text-luxury-cream hover:text-luxury-gold transition-colors duration-300 mt-7">
        <span class="border-b border-luxury-gold/50 pb-1 group-hover:border-luxury-gold transition-colors">Enter the Atelier</span>
        <span class="transition-transform duration-300 group-hover:translate-x-1">&rarr;</span>
      </a>

      <!-- Slide indicators — auto-advance, but clickable too -->
      <div class="flex items-center gap-3 mt-8">
        {slides.map((_, i) => (
          <button
            class="slide-dot w-1.5 h-1.5 rounded-full transition-all duration-300"
            data-slide-index={i}
            class:list={[i === 0 ? "bg-luxury-gold w-4" : "bg-luxury-cream/30"]}
            aria-label={`Show slide ${i + 1}`}
          />
        ))}
      </div>
    </div>

  </div>
</section>

<style>
  .hero-fade-in {
    opacity: 0;
    transform: translateY(12px);
    animation: heroFadeIn 1.1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  @keyframes heroFadeIn {
    to { opacity: 1; transform: translateY(0); }
  }

  /* Creative reveal — the photo opens like an aperture, then settles */
  .hero-reveal-clip {
    clip-path: inset(42% 0 42% 0);
    animation: heroClipReveal 1.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: 0.15s;
  }
  .hero-reveal-clip #parallax-frame {
    transform: scale(1.08);
    animation: heroImageSettle 1.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: 0.15s;
  }
  @keyframes heroClipReveal {
    to { clip-path: inset(0 0 0 0); }
  }
  @keyframes heroImageSettle {
    to { transform: scale(1); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-fade-in { animation: none; opacity: 1; transform: none; }
    .hero-reveal-clip { animation: none; clip-path: inset(0 0 0 0); }
    .hero-reveal-clip #parallax-frame { animation: none; transform: none; }
    .hero-slide, .ambient-glow { transition: none !important; }
  }
</style>

<script>
  const trigger = document.getElementById('menu-trigger');
  const overlay = document.getElementById('nav-overlay');
  const closeBtn = document.getElementById('close-nav');
  const navLinks = overlay?.querySelectorAll('.nav-link');

  function openNav() {
    overlay?.classList.remove('pointer-events-none', 'opacity-0');
    overlay?.classList.add('opacity-100');
    trigger?.setAttribute('aria-expanded', 'true');
  }
  function closeNav() {
    overlay?.classList.add('pointer-events-none', 'opacity-0');
    overlay?.classList.remove('opacity-100');
    trigger?.setAttribute('aria-expanded', 'false');
  }
  trigger?.addEventListener('click', openNav);
  closeBtn?.addEventListener('click', closeNav);
  navLinks?.forEach(link => link.addEventListener('click', closeNav));
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeNav(); });

  // Slideshow — auto-advance every 4.5s, crossfade image + ambient glow together
  const slideEls = document.querySelectorAll('.hero-slide');
  const glowEls = document.querySelectorAll('.ambient-glow');
  const dots = document.querySelectorAll('.slide-dot');
  let current = 0;
  let timer: number;

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function showSlide(index: number) {
    slideEls.forEach(el => {
      (el as HTMLElement).style.opacity = el.getAttribute('data-slide-index') === String(index) ? '1' : '0';
    });
    glowEls.forEach(el => {
      (el as HTMLElement).style.opacity = el.getAttribute('data-slide-index') === String(index) ? '1' : '0';
    });
    dots.forEach(dot => {
      const isActive = dot.getAttribute('data-slide-index') === String(index);
      dot.classList.toggle('bg-luxury-gold', isActive);
      dot.classList.toggle('w-4', isActive);
      dot.classList.toggle('bg-luxury-cream/30', !isActive);
    });
    current = index;
  }

  function nextSlide() {
    showSlide((current + 1) % slideEls.length);
  }

  function startAutoplay() {
    if (prefersReducedMotion) return;
    stopAutoplay();
    timer = window.setInterval(nextSlide, 4500);
  }
  function stopAutoplay() {
    if (timer) clearInterval(timer);
  }

  dots.forEach(dot => {
    dot.addEventListener('click', () => {
      showSlide(Number(dot.getAttribute('data-slide-index')));
      startAutoplay();
    });
  });

  startAutoplay();

  // Subtle scroll parallax on the image frame
  const parallaxFrame = document.getElementById('parallax-frame');
  if (!prefersReducedMotion && parallaxFrame) {
    window.addEventListener('scroll', () => {
      const offset = Math.min(window.scrollY * 0.06, 30);
      parallaxFrame.style.transform = `translateY(${offset}px)`;
    }, { passive: true });
  }
</script>
