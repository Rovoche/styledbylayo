---
// Hero.astro
const base = import.meta.env.BASE_URL;
---

<!-- Minimal Wordmark Header — nav weight removed, single menu trigger only -->
<header class="absolute top-0 left-0 w-full z-40 px-6 py-7 lg:px-12 lg:py-9 flex justify-between items-center">
  <a href="#top" class="font-display text-xl lg:text-2xl font-light tracking-[0.25em] text-luxury-cream hover:text-luxury-gold transition-colors duration-300">
    STYLEDBYLAYO
  </a>

  <button
    id="menu-trigger"
    aria-label="Open menu"
    aria-expanded="false"
    class="flex items-center gap-3 text-luxury-cream hover:text-luxury-gold transition-colors duration-300 group"
  >
    <span class="text-[10px] uppercase tracking-[0.35em] font-sans font-medium hidden sm:inline">Menu</span>
    <span class="flex flex-col justify-between h-3 w-5">
      <span class="w-full h-[1px] bg-current"></span>
      <span class="w-full h-[1px] bg-current"></span>
    </span>
  </button>
</header>

<!-- Full-Screen Nav Overlay (shared by all viewports now — keeps the hero itself uncluttered) -->
<div
  id="nav-overlay"
  class="fixed inset-0 z-50 bg-[#070605] flex flex-col justify-center items-center gap-7 lg:gap-9 uppercase tracking-[0.35em] font-editorial text-2xl lg:text-4xl font-light text-luxury-cream opacity-0 pointer-events-none transition-opacity duration-500"
>
  <button id="close-nav" aria-label="Close menu" class="absolute top-7 right-6 lg:top-9 lg:right-12 text-luxury-cream hover:text-luxury-gold transition-colors text-2xl font-sans">
    ×
  </button>
  <a href="#signature" class="nav-link hover:text-luxury-gold transition-colors duration-300">Masterpieces</a>
  <a href="#archive" class="nav-link hover:text-luxury-gold transition-colors duration-300">Archive</a>
  <a href="#academy" class="nav-link hover:text-luxury-gold transition-colors duration-300">SBLFA Academy</a>
  <a href="#craft" class="nav-link hover:text-luxury-gold transition-colors duration-300">Our Ethos</a>
  <a href="#contact" class="nav-link border border-luxury-gold/40 px-8 py-3 text-sm lg:text-base tracking-[0.3em] text-luxury-gold hover:bg-luxury-gold hover:text-black transition-all duration-300 mt-2">
    Private Consultation
  </a>
</div>

<section id="top" class="relative min-h-screen w-full bg-luxury-dark overflow-hidden flex items-center pt-28 pb-16 lg:pt-0 lg:pb-0">
  <!-- Ambient depth glow behind the garment, not over it -->
  <div class="absolute right-0 top-1/4 w-1/2 h-1/2 bg-[radial-gradient(circle,rgba(201,169,110,0.08),transparent_70%)] pointer-events-none"></div>

  <div class="relative z-10 max-w-7xl mx-auto w-full px-6 lg:px-12 grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-center">

    <!-- Editorial Copy Block -->
    <div class="lg:col-span-5 lg:order-1 flex flex-col hero-reveal" style="animation-delay: 0.1s">
      <span class="text-[10px] uppercase tracking-[0.5em] text-luxury-gold font-sans font-semibold mb-6 block">
        Look N&deg; 02 &mdash; Eveningwear
      </span>
      <h1 class="text-5xl sm:text-6xl lg:text-7xl xl:text-8xl font-thin tracking-tight font-editorial leading-[0.95] text-luxury-cream mb-8">
        The Emerald<br />
        <span class="italic text-luxury-gold font-light">Couture Gown</span>
      </h1>
      <p class="text-sm lg:text-base font-sans font-light tracking-wide text-luxury-cream/70 leading-relaxed max-w-md mb-10">
        Hand-linked bead strings trace a backless architecture, built to move like Lagos light across deep jewel tones. A single silhouette, fitted to one woman, once.
      </p>
      
        href="#signature"
        class="group inline-flex items-center gap-4 text-xs uppercase tracking-[0.3em] font-sans font-medium text-luxury-cream hover:text-luxury-gold transition-colors duration-300 w-fit"
      >
        <span class="border-b border-luxury-gold/50 pb-1 group-hover:border-luxury-gold transition-colors">Enter the Atelier</span>
        <span class="transition-transform duration-300 group-hover:translate-x-1">&rarr;</span>
      </a>
    </div>

    <!-- Garment Frame — native 4:5 ratio preserved, nothing cropped -->
    <div class="lg:col-span-7 lg:order-2 flex justify-center lg:justify-end hero-reveal" style="animation-delay: 0.3s">
      <div class="relative w-full max-w-md lg:max-w-lg">
        <img
          src={`${base}emerald-beaded-couture-gown.1.jpg`}
          alt="The Emerald Couture Gown, full silhouette"
          referrerpolicy="no-referrer"
          class="w-full h-auto object-contain relative z-10"
        />
        <span class="absolute -bottom-6 -left-6 lg:-left-10 text-[9px] uppercase tracking-[0.3em] text-luxury-cream/40 font-sans hidden lg:block">
          Backless Column Gown
        </span>
      </div>
    </div>
  </div>

  <!-- Quiet static tag line — replaces the old scrolling marquee for a calmer first screen -->
  <div class="absolute bottom-0 left-0 w-full border-t border-luxury-gold/10 py-5 px-6 lg:px-12">
    <p class="text-center text-[9px] lg:text-[10px] uppercase tracking-[0.4em] text-luxury-cream/40 font-sans">
      Bridal <span class="text-luxury-gold/50 mx-2">&middot;</span> Eveningwear <span class="text-luxury-gold/50 mx-2">&middot;</span> Ready-to-Wear <span class="text-luxury-gold/50 mx-2">&middot;</span> Menswear <span class="text-luxury-gold/50 mx-2">&middot;</span> SBLFA Academy
    </p>
  </div>
</section>

<style>
  .hero-reveal {
    opacity: 0;
    transform: translateY(16px);
    animation: heroReveal 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes heroReveal {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-reveal {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  const trigger = document.getElementById('menu-trigger');
  const overlay = document.getElementById('nav-overlay');
  const closeBtn = document.getElementById('close-nav');
  const links = overlay?.querySelectorAll('.nav-link');

  function openNav() {
    overlay?.classList.remove('pointer-events-none', 'opacity-0');
    overlay?.classList.add('opacity-100');
    trigger?.setAttribute('aria-expanded', 'true');
  }

  function closeNav() {
    overlay?.classList.add('pointer-events-none', 'opacity-0');
    overlay?.classList.remove('opacity-100');
    trigger?.setAttribute('aria-expanded', 'false');
  }

  trigger?.addEventListener('click', openNav);
  closeBtn?.addEventListener('click', closeNav);
  links?.forEach(link => link.addEventListener('click', closeNav));

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeNav();
  });
</script>
