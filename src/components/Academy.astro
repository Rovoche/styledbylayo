---
// Academy.astro
const courses = [
  {
    code: "SBLFA-101",
    title: "Executive Pattern Drafting",
    duration: "12 Weeks • In-Person",
    focus: "Millimeter accuracy pattern construction, dart manipulations, and bespoke sizing templates.",
    level: "Intermediate to Advanced"
  },
  {
    code: "SBLFA-202",
    title: "Haute Couture & Finishings",
    duration: "16 Weeks • Intense Masterclass",
    focus: "Traditional hand-stitched hem techniques, glass-bead application, corset boning, and draping.",
    level: "Advanced Professional"
  },
  {
    code: "SBLFA-303",
    title: "Bespoke Menswear Construction",
    duration: "8 Weeks • In-Person",
    focus: "Canvas structures, pattern shoulders layout, sleeve-pitching, and luxury fabric handling.",
    level: "Intermediate to Professional"
  }
];
---

<section id="academy" class="py-24 lg:py-36 bg-[#070605] text-luxury-cream px-6 lg:px-12 border-b border-luxury-gold/10 relative overflow-hidden">
  <!-- Glowing subtle circle background -->
  <div class="absolute -right-36 top-1/4 w-96 h-96 rounded-full bg-luxury-gold/5 blur-3xl pointer-events-none"></div>
  
  <div class="max-w-7xl mx-auto">
    <!-- Section Introduction -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-end mb-20 lg:mb-28">
      <div class="lg:col-span-8">
        <span class="text-[10px] uppercase tracking-[0.55em] text-luxury-gold font-sans font-semibold inline-block mb-3">SBLFA Academy</span>
        <h2 class="text-4xl lg:text-7xl font-thin tracking-tight font-editorial leading-none">
          Cultivating <br />
          <span class="italic text-luxury-gold font-light">Masters of the Craft</span>
        </h2>
      </div>
      <div class="lg:col-span-4 pl-0 lg:pl-6 border-l-0 lg:border-l border-luxury-gold/20">
        <p class="text-sm font-sans font-light tracking-wide text-luxury-cream/70 leading-relaxed">
          The SBL Fashion Academy (SBLFA) is Nigeria's premier training destination for high-end fashion execution. Here, drafts become masterpieces, and hand skills are honed to absolute global competitive perfection.
        </p>
      </div>
    </div>

    <!-- Courses Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-20">
      {courses.map((course, index) => (
        <div class="group relative bg-[#0d0c0a] border border-luxury-gold/10 hover:border-luxury-gold/30 p-8 lg:p-10 flex flex-col justify-between transition-all duration-500 hover:-translate-y-1">
          <!-- Hover top decoration bar -->
          <div class="absolute inset-x-0 top-0 h-[2px] bg-luxury-gold scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left"></div>

          <div>
            <div class="flex justify-between items-center mb-8">
              <span class="text-[9px] uppercase tracking-[0.2em] font-sans text-luxury-gold border border-luxury-gold/30 px-3 py-1 font-semibold">
                {course.code}
              </span>
              <span class="text-[9px] uppercase tracking-[0.15em] font-sans text-luxury-cream/40">
                {course.level}
              </span>
            </div>
            
            <h3 class="font-editorial text-2xl lg:text-3xl font-thin tracking-wide mb-4 text-luxury-cream group-hover:text-luxury-gold transition-colors duration-300">
              {course.title}
            </h3>
            
            <p class="text-xs font-sans font-light text-luxury-cream/70 leading-relaxed mb-6">
              {course.focus}
            </p>
          </div>

          <div class="mt-8 pt-6 border-t border-luxury-gold/10 flex justify-between items-center text-[10px] uppercase tracking-[0.2em] font-sans text-luxury-cream/50">
            <span>Duration:</span>
            <span class="text-luxury-cream font-medium group-hover:text-luxury-gold transition-colors duration-300">{course.duration}</span>
          </div>
        </div>
      ))}
    </div>

    <!-- Callout Box -->
    <div class="bg-[#0b0a09] border border-luxury-gold/15 p-8 lg:p-16 text-center max-w-4xl mx-auto flex flex-col items-center">
      <span class="text-[9px] uppercase tracking-[0.5em] text-luxury-gold font-sans font-semibold mb-4">Admissions Open</span>
      <h3 class="font-editorial text-2xl lg:text-4xl font-light tracking-wide text-luxury-cream mb-6">
        Enroll in the <span class="italic text-luxury-gold">Next Masterclass Cohort</span>
      </h3>
      <p class="text-xs font-sans font-light tracking-wider text-luxury-cream/60 max-w-lg mb-8 leading-relaxed">
        Admission to SBLFA is highly selective. We accept a maximum of 12 designers per class to ensure precise, individualized guidance from master-level instructors.
      </p>
      <a 
        href="#contact" 
        class="bg-luxury-gold hover:bg-luxury-cream hover:text-black border border-transparent text-black px-8 py-3 text-xs uppercase tracking-[0.25em] font-sans font-medium transition-all duration-500"
      >
        Download Syllabus
      </a>
    </div>
  </div>
</section>
